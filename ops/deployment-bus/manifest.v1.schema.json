{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://6529.io/schemas/deployment-bus-manifest.v1.schema.json",
  "title": "6529 Deployment Bus Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "repository",
    "environment",
    "status",
    "created_at",
    "updated_at",
    "release_captain",
    "complexity",
    "production_eligible",
    "shas",
    "lane",
    "included_prs",
    "backend_dependencies",
    "validation",
    "deployment",
    "long_running",
    "plans",
    "human_gates",
    "progress"
  ],
  "properties": {
    "schema_version": {
      "const": "deployment-bus.v1"
    },
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "environment": {
      "enum": ["staging", "production"]
    },
    "status": {
      "enum": [
        "collecting",
        "queued",
        "leased",
        "dispatching",
        "deploying",
        "deploy_verified",
        "validating",
        "passed",
        "failed",
        "held",
        "superseded",
        "stale",
        "promoting",
        "released",
        "rollback_required",
        "rolled_back",
        "fix_forward_required",
        "cancelled"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "release_captain": {
      "type": "string",
      "minLength": 1
    },
    "complexity": {
      "enum": ["standard", "complex", "hotfix", "emergency"]
    },
    "production_eligible": {
      "type": "boolean"
    },
    "staging_branch": {
      "type": ["string", "null"]
    },
    "shas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["staging_deploy_sha", "production_candidate_sha"],
      "properties": {
        "staging_deploy_sha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-fA-F]{40}$"
        },
        "production_candidate_sha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-fA-F]{40}$"
        }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "acquired_at",
        "heartbeat_at",
        "heartbeat_interval_minutes",
        "stale_after_minutes",
        "expected_duration_minutes",
        "expected_completion_at"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "acquired_at": {
          "type": "string",
          "format": "date-time"
        },
        "heartbeat_at": {
          "type": "string",
          "format": "date-time"
        },
        "heartbeat_interval_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "stale_after_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "expected_duration_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "expected_completion_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "included_prs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["number", "title", "merge_sha", "risk", "areas", "validation_owner", "status"],
        "properties": {
          "number": { "type": "integer" },
          "title": { "type": "string" },
          "author": { "type": "string" },
          "merge_sha": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{40}$"
          },
          "risk": { "type": "string" },
          "areas": {
            "type": "array",
            "items": { "type": "string" }
          },
          "validation_owner": { "type": "string" },
          "required_checks": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": { "type": "string" }
        }
      }
    },
    "backend_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["core_smoke_owner", "required_packs", "exploratory_checks", "checks"],
      "properties": {
        "core_smoke_owner": { "type": "string" },
        "required_packs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exploratory_checks": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "checks": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "github_deployment_id",
        "workflow_run_url",
        "environment_url",
        "ssm_command_id",
        "elastic_beanstalk_version_label"
      ],
      "properties": {
        "github_deployment_id": { "type": ["string", "integer", "null"] },
        "workflow_run_url": { "type": ["string", "null"] },
        "environment_url": { "type": ["string", "null"] },
        "ssm_command_id": { "type": ["string", "null"] },
        "elastic_beanstalk_version_label": { "type": ["string", "null"] }
      }
    },
    "long_running": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "heartbeat_interval_minutes": { "type": "integer", "minimum": 1 },
        "progress_update_channels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "escalation_after_minutes": { "type": "integer", "minimum": 1 },
        "checkpoint_labels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "plans": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rollback", "fix_forward"],
      "properties": {
        "rollback": { "type": "string" },
        "fix_forward": { "type": "string" }
      }
    },
    "human_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["production_approval_required", "approvals", "override_reason"],
      "properties": {
        "production_approval_required": { "type": "boolean" },
        "approvals": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "override_reason": { "type": ["string", "null"] }
      }
    },
    "progress": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["at", "phase", "message"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "phase": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
