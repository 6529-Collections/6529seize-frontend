{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "incremental": false,
    "jsx": "react-jsx",
    "moduleDetection": "force",
    "noEmit": true,
    "types": ["node", "jest", "@testing-library/jest-dom"]
  },
  "include": [
    "next-env.typecheck.d.ts",
    "**/*.d.ts",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "__mocks__/**/*.ts",
    "__mocks__/**/*.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "exclude": [
    "node_modules",
    "generated/**",
    "tests/**",
    "e2e/**",
    ".next/**",
    ".next-*/**",
    ".claude/**",
    ".codex/**"
  ]
}
