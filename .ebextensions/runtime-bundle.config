container_commands:
  01_install_runtime_dependencies:
    command: |
      if [ -f package.json.seize-real ]; then
        mv package.json.seize-real package.json
      fi
      rm -rf node_modules package-lock.json npm-shrinkwrap.json
      package_manager="$(node -p 'require("./package.json").packageManager')"
      export COREPACK_HOME="${COREPACK_HOME:-/tmp/.cache/6529-corepack}"
      export COREPACK_ENABLE_DOWNLOAD_PROMPT="0"
      if command -v corepack >/dev/null 2>&1; then
        corepack enable pnpm
        corepack prepare "$package_manager" --activate
      else
        npm install --global "$package_manager"
        export PATH="$(npm prefix -g)/bin:$PATH"
      fi
      SEIZE_SECURE_INSTALL=1 pnpm install --frozen-lockfile --prod
  02_verify_runtime_bundle:
    command: |
      test -d node_modules
      test -f .next/BUILD_ID
