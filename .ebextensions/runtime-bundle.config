container_commands:
  01_install_runtime_dependencies:
    command: |
      export COREPACK_HOME="${COREPACK_HOME:-/tmp/.cache/6529-corepack}"
      export COREPACK_ENABLE_DOWNLOAD_PROMPT="0"
      corepack enable pnpm
      corepack prepare "$(node -p 'require("./package.json").packageManager')" --activate
      SEIZE_SECURE_INSTALL=1 pnpm install --frozen-lockfile --prod
  02_verify_runtime_bundle:
    command: |
      test -d node_modules
      test -f .next/BUILD_ID
