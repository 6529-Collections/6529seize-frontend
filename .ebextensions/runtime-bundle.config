container_commands:
  01_install_dependencies:
    command: |
      corepack enable pnpm
      corepack prepare pnpm@10.33.0 --activate
      SEIZE_6529_COMMAND=1 SEIZE_SECURE_INSTALL=1 pnpm install --frozen-lockfile --prod
  02_verify_runtime_bundle:
    command: |
      test -d node_modules
      test -f .next/BUILD_ID
