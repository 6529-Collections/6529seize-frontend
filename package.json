{
  "name": "6529seize",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:env-schema": "node scripts/build-env-schema.cjs",
    "export-mint-page": "npm run build:env-schema && node standalone/standalone-memes-mint/scripts/export-mint-page.cjs",
    "export-mint-page:sync": "npm run export-mint-page -- --sync",
    "export-mint-page:test": "npm run export-mint-page -- --test",
    "export-mint-page:test:sync": "npm run export-mint-page -- --test --sync",
    "predev": "npm run build:env-schema",
    "dev": "node scripts/dev-with-fallback.cjs",
    "dev:webpack": "USE_TURBO=false node scripts/dev-with-fallback.cjs",
    "dev:open": "node scripts/dev-open.cjs",
    "generate": "rm -rf tmp_gen_outp && node ./node_modules/@openapitools/openapi-generator-cli/main generate -i openapi.yaml -g typescript -o tmp_gen_outp --additional-properties=modelPropertyNaming=snake_case && rm -rf generated && mkdir generated && mv tmp_gen_outp/models generated/models && rm -rf tmp_gen_outp && mkdir generated/http && echo 'export type HttpFile = any;' > generated/http/http.ts && rm generated/models/all.ts && bash scripts/add-ts-nocheck.sh",
    "base-build": "cross-env NODE_OPTIONS=--max-old-space-size=7680 next build",
    "build": "npm run lint:quiet && npm run base-build",
    "prebuild": "npm run build:env-schema && npm run generate",
    "postbuild": "next-sitemap --config next-sitemap.config.ts",
    "start": "next start -p 3001",
    "test": "cross-env NODE_ENV=test jest --silent --verbose=false --coverageReporters=none",
    "test:no-coverage": "cross-env NODE_ENV=test jest --silent --verbose=false --coverage=false",
    "test-json": "cross-env NODE_ENV=test jest --silent --json --outputFile=test-results/jest-results.json --coverage=false --forceExit ; npm run test-extract-failed-names",
    "test-json-changed": "cross-env NODE_ENV=test jest --silent --json --outputFile=test-results/jest-results.json --changedSince=main --coverage=false --forceExit ; npm run test-extract-failed-names",
    "test-extract-failed-names": "node test-results/list-failed-tests.cjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "knip": "knip --fix --allow-remove-files",
    "lint:package-json": "npmPkgJsonLint -c .npmpackagejsonlintrc.json .",
    "lint:quiet": "eslint . --quiet",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:changed": "node scripts/typecheck-changed.cjs",
    "lint:csv": "node scripts/eslint-rule-summary.cjs --output eslint-rule-summary.csv",
    "lint:csv:tight": "node scripts/eslint-rule-summary.cjs --config eslint.config.tight.mjs --output eslint-rule-summary.csv",
    "lint:changed:csv": "node scripts/eslint-rule-summary.cjs --changed --output eslint-rule-summary.csv",
    "lint:changed:csv:tight": "node scripts/eslint-rule-summary.cjs --changed --config eslint.config.tight.mjs --output eslint-rule-summary.csv",
    "lint:changed": "bash -lc '{ git diff --name-only -z --diff-filter=ACMR main...HEAD -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; git ls-files --others --exclude-standard -z -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; } | xargs -0 npx eslint  --no-warn-ignored --max-warnings=0'",
    "lint:changed:fix": "bash -lc '{ git diff --name-only -z --diff-filter=ACMR main...HEAD -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; git ls-files --others --exclude-standard -z -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; } | xargs -0 npx eslint --fix --no-warn-ignored --max-warnings=0'",
    "lint:changed:tight": "bash -lc '{ git diff --name-only -z --diff-filter=ACMR main...HEAD -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; git ls-files --others --exclude-standard -z -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; } | xargs -0 npx eslint --config eslint.config.tight.mjs --no-warn-ignored --max-warnings=0'",
    "lint:uncommitted:tight": "bash -lc '{ git diff --name-only -z --diff-filter=ACMR HEAD -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; git ls-files --others --exclude-standard -z -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; } | xargs -0 npx eslint --config eslint.config.tight.mjs --no-warn-ignored --max-warnings=0'",
    "lint:fix": "npx eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:single": "npx eslint --config eslint.config.single.mjs",
    "lint:diff": "bash -lc '{ git diff --name-only -z --diff-filter=ACMR HEAD -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; git ls-files --others --exclude-standard -z -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \":(exclude)generated/**\"; } | xargs -0 npx eslint --config eslint.config.diff.mjs --no-warn-ignored --max-warnings=0'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:changed": "bash -lc '{ git diff --name-only -z --diff-filter=ACMR main...HEAD -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \"*.json\" \"*.css\" \"*.scss\" \":(exclude)generated/**\"; git ls-files --others --exclude-standard -z -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \"*.json\" \"*.css\" \"*.scss\" \":(exclude)generated/**\"; } | xargs -0 prettier --write --ignore-unknown'",
    "format:uncommitted": "bash -lc '{ git diff --name-only -z --diff-filter=ACMR HEAD -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \"*.json\" \"*.css\" \"*.scss\" \":(exclude)generated/**\"; git ls-files --others --exclude-standard -z -- \"*.js\" \"*.jsx\" \"*.ts\" \"*.tsx\" \"*.json\" \"*.css\" \"*.scss\" \":(exclude)generated/**\"; } | xargs -0 prettier --write --ignore-unknown'",
    "deadcode:knip": "knip",
    "deadcode:deps": "depcheck --ignores=\"eslint,eslint-*,@types/*,jest,ts-jest,playwright,@playwright/test,tailwindcss,postcss,autoprefixer\" --ignore-patterns=\".next,coverage,public,generated,tmp_gen_outp\"",
    "deadcode": "npm run deadcode:knip && npm run deadcode:deps",
    "cr": "coderabbit --type uncommitted --base main --prompt-only",
    "sync": "bash scripts/worktree/wt-sync.sh",
    "quality": "node scripts/quality.js",
    "quality:changed": "node scripts/quality.js --changed",
    "quality:cr": "node scripts/quality.js --coderabbit",
    "quality:cr:changed": "node scripts/quality.js --changed --coderabbit"
  },
