#!/usr/bin/env bash

set -euo pipefail

export COREPACK_HOME="${COREPACK_HOME:-${HOME:-${TMPDIR:-/tmp}}/.cache/6529-corepack}"
export COREPACK_ENABLE_DOWNLOAD_PROMPT="0"
export SEIZE_6529_COMMAND="1"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

command_name="${1:-}"

if [[ -z "$command_name" ]]; then
  cat <<'EOF'
Usage:
  6529 <command> [args...]

Common commands:
  6529 bootstrap       -> enable the repo-scoped 6529 command for future shells
  6529 install         -> pnpm run install:secure
  6529 i               -> pnpm run install:secure
  6529 install:frozen  -> pnpm run install:secure:frozen
  6529 ci              -> pnpm run install:secure:frozen
  6529 install:prod    -> pnpm run install:secure:prod
  6529 update          -> sfw pnpm audit --fix
  6529 update:all      -> sfw pnpm update
  6529 run dev         -> pnpm run dev
  6529 run build       -> pnpm run build
  6529 approve-builds  -> pnpm approve-builds
  6529 prune:prod      -> pnpm run prune:prod
  6529 staging         -> bash repo-rooted scripts/staging.sh
  6529 env status      -> show selected .env API/WS target
  6529 env <env>       -> switch .env API/WS target to local, staging, or prod
  6529 run start       -> pnpm run start
  6529 run test        -> pnpm run test
  6529 run lint        -> pnpm run lint

Anything else is forwarded to pnpm unchanged.
EOF
  exit 1
fi

shift

case "$command_name" in
  bootstrap)
    exec bash "$REPO_ROOT/scripts/bootstrap-6529-command.sh" "$@"
    ;;
  staging)
    exec bash "$REPO_ROOT/scripts/staging.sh" "$@"
    ;;
  env)
    exec node "$REPO_ROOT/scripts/env-target.cjs" "$@"
    ;;
esac

clean_path=""
IFS=':' read -r -a path_parts <<< "${PATH:-}"
for part in "${path_parts[@]}"; do
  if [[ -z "$part" || "$part" == "$SCRIPT_DIR" ]]; then
    continue
  fi
  if [[ -z "$clean_path" ]]; then
    clean_path="$part"
  else
    clean_path="${clean_path}:$part"
  fi
done

REAL_PNPM="$(PATH="$clean_path" command -v pnpm || true)"

if [[ -z "$REAL_PNPM" ]]; then
  echo "pnpm is not available. Activate the repo-pinned pnpm with Corepack first." >&2
  exit 1
fi

cd "$REPO_ROOT"

case "$command_name" in
  dev|dev:webpack|dev:open|build|test|lint|start)
    echo "Use \`6529 run $command_name\` for package.json scripts." >&2
    exit 1
    ;;
  i)
    if [[ "$#" -gt 0 ]]; then
      echo "Use \`6529 add <package>\` to add dependencies." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure "$@"
    ;;
  install)
    if [[ "$#" -gt 0 ]]; then
      echo "Use \`6529 add <package>\` to add dependencies." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure "$@"
    ;;
  ci)
    if [[ "$#" -gt 0 ]]; then
      echo "\`6529 ci\` does not accept package arguments." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure:frozen "$@"
    ;;
  install:frozen)
    if [[ "$#" -gt 0 ]]; then
      echo "\`6529 install:frozen\` does not accept package arguments." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure:frozen "$@"
    ;;
  install:prod)
    if [[ "$#" -gt 0 ]]; then
      echo "\`6529 install:prod\` does not accept package arguments." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure:prod "$@"
    ;;
  add)
    if [[ "$#" -eq 0 ]]; then
      echo "Usage: \`6529 add <package>\`" >&2
      exit 1
    fi
    node "$REPO_ROOT/scripts/assert-no-package-lock.cjs"
    exec node "$REPO_ROOT/scripts/run-secure-pnpm.cjs" add "$@"
    ;;
  update)
    if [[ "$#" -gt 0 ]]; then
      echo "\`6529 update\` runs audit fixes and does not accept package arguments." >&2
      echo "Use \`6529 update:all [package...]\` for intentional pnpm updates." >&2
      exit 1
    fi
    node "$REPO_ROOT/scripts/assert-no-package-lock.cjs"
    exec node "$REPO_ROOT/scripts/run-secure-pnpm.cjs" audit --fix
    ;;
  update:all)
    node "$REPO_ROOT/scripts/assert-no-package-lock.cjs"
    exec node "$REPO_ROOT/scripts/run-secure-pnpm.cjs" update "$@"
    ;;
  prune:prod)
    exec "$REAL_PNPM" run prune:prod "$@"
    ;;
  run)
    exec "$REAL_PNPM" run "$@"
    ;;
  exec)
    if [[ "${1:-}" == "jest" && "${NODE_OPTIONS:-}" != *"--max-old-space-size="* ]]; then
      export NODE_OPTIONS="${NODE_OPTIONS:+$NODE_OPTIONS }--max-old-space-size=6144"
    fi
    exec "$REAL_PNPM" exec "$@"
    ;;
  *)
    exec "$REAL_PNPM" "$command_name" "$@"
    ;;
esac
