#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "${SEIZE_6529_COMMAND:-0}" != "1" && "${SEIZE_SECURE_INSTALL:-0}" != "1" ]]; then
  echo "Direct pnpm usage is blocked in this repository." >&2
  echo "Use the \`6529\` wrapper instead." >&2
  echo "Examples:" >&2
  echo "  6529 install" >&2
  echo "  6529 run dev" >&2
  echo "  6529 run build" >&2
  exit 1
fi

clean_path=""
IFS=':' read -r -a path_parts <<< "${PATH:-}"
for part in "${path_parts[@]}"; do
  if [[ -z "$part" || "$part" == "$SCRIPT_DIR" ]]; then
    continue
  fi
  if [[ -z "$clean_path" ]]; then
    clean_path="$part"
  else
    clean_path="${clean_path}:$part"
  fi
done

REAL_PNPM="$(PATH="$clean_path" command -v pnpm || true)"

if [[ -z "$REAL_PNPM" ]]; then
  echo "Unable to locate the real pnpm binary outside the repo wrapper path." >&2
  exit 1
fi

exec "$REAL_PNPM" "$@"
